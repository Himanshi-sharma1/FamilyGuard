// FamilyGuard Dashboard Application

// State
let token = localStorage.getItem('familyguard_token');
let user = JSON.parse(localStorage.getItem('familyguard_user') || 'null');
let socket = null;
let liveMap = null;
let fullMap = null;
let currentMarker = null;
let routePolyline = null;
let geofenceCircle = null;
let healthCharts = {};

// API Base URL
const API_URL = '/api/v1';

// Initialize
document.addEventListener('DOMContentLoaded', () => {
  lucide.createIcons();
  
  if (token && user) {
    showDashboard();
  } else {
    showLogin();
  }
  
  // Login form handler
  document.getElementById('login-form').addEventListener('submit', handleLogin);
});

// Auth Functions
async function handleLogin(e) {
  e.preventDefault();
  
  const username = document.getElementById('username').value;
  const password = document.getElementById('password').value;
  const errorEl = document.getElementById('login-error');
  
  try {
    const response = await fetch(`${API_URL}/auth/login`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ username, password })
    });
    
    const data = await response.json();
    
    if (!response.ok) {
      throw new Error(data.error || 'Login failed');
    }
    
    token = data.token;
    user = data.user;
    
    localStorage.setItem('familyguard_token', token);
    localStorage.setItem('familyguard_user', JSON.stringify(user));
    
    showDashboard();
  } catch (err) {
    errorEl.textContent = err.message;
    errorEl.classList.remove('hidden');
  }
}

function logout() {
  token = null;
  user = null;
  localStorage.removeItem('familyguard_token');
  localStorage.removeItem('familyguard_user');
  
  if (socket) {
    socket.disconnect();
  }
  
  showLogin();
}

function showLogin() {
  document.getElementById('login-page').style.display = 'flex';
  document.getElementById('dashboard').classList.remove('active');
}

function showDashboard() {
  document.getElementById('login-page').style.display = 'none';
  document.getElementById('dashboard').classList.add('active');
  
  // Update user info
  document.getElementById('user-avatar').textContent = user.name ? user.name[0].toUpperCase() : 'U';
  document.getElementById('user-name').textContent = user.name || user.username;
  
  // Initialize Socket.IO
  initSocket();
  
  // Load initial data
  loadStatus();
  loadAlertCount();
  
  // Navigate to overview
  navigateTo('overview');
  
  lucide.createIcons();
}

// Socket.IO
function initSocket() {
  socket = io();
  
  socket.on('connect', () => {
    console.log('Connected to server');
    socket.emit('join:dashboard');
  });
  
  socket.on('location:update', (data) => {
    updateLocation(data);
  });
  
  socket.on('alert:new', (alert) => {
    showNotification(alert.title, alert.message);
    loadAlertCount();
    
    if (alert.type === 'sos' || alert.type === 'fall') {
      showCriticalBanner(alert);
    }
  });
  
  socket.on('checkin:new', (checkin) => {
    updateLastCheckin(checkin);
    showNotification('Check-in Received', 'Father has checked in');
  });
  
  socket.on('sos:triggered', (sos) => {
    showCriticalBanner({ type: 'sos', title: 'SOS EMERGENCY', message: 'Father has triggered an emergency alert!' });
  });
  
  socket.on('status:change', (status) => {
    updateStatusSidebar(status);
  });
  
  socket.on('health:update', (health) => {
    if (health.type === 'mood') {
      document.getElementById('current-mood').textContent = getMoodEmoji(health.value);
    } else if (health.type === 'steps') {
      document.getElementById('steps-today').textContent = formatNumber(health.value);
    }
  });
}

// Navigation
function navigateTo(page) {
  // Update nav items
  document.querySelectorAll('.nav-item').forEach(item => {
    item.classList.remove('active');
  });
  
  const navItem = document.querySelector(`[data-testid="nav-${page}"]`);
  if (navItem) navItem.classList.add('active');
  
  // Load page content
  const content = document.getElementById('main-content');
  
  switch (page) {
    case 'overview':
      loadOverviewPage(content);
      break;
    case 'map':
      loadMapPage(content);
      break;
    case 'alerts':
      loadAlertsPage(content);
      break;
    case 'health':
      loadHealthPage(content);
      break;
    case 'media':
      loadMediaPage(content);
      break;
    case 'call':
      loadCallPage(content);
      break;
    case 'messages':
      loadMessagesPage(content);
      break;
    case 'reports':
      loadReportsPage(content);
      break;
    case 'settings':
      loadSettingsPage(content);
      break;
    default:
      loadOverviewPage(content);
  }
}

