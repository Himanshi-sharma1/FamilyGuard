function renderVoice(voice) {
  return `
    <div class="voice-item">
      <button class="voice-play-btn" onclick="playVoice('${voice.file_url}')" data-testid="play-voice-${voice.id}">
        <i data-lucide="play"></i>
      </button>
      <div class="voice-info">
        <div class="voice-duration">${voice.duration ? formatDuration(voice.duration) : 'Voice message'}</div>
        <div class="voice-time">${formatTime(voice.created_at)}</div>
      </div>
    </div>
  `;
}

function playVoice(url) {
  const audio = new Audio(url);
  audio.play();
}

async function loadHealthData() {
  try {
    const data = await fetchWithAuth(`${API_URL}/health/summary`);
    
    // Update current values
    const moodEl = document.getElementById('health-mood');
    const stepsEl = document.getElementById('health-steps');
    const waterEl = document.getElementById('health-water');
    const sleepEl = document.getElementById('health-sleep');
    
    if (moodEl) moodEl.textContent = data.today?.mood ? getMoodEmoji(data.today.mood) : '--';
    if (stepsEl) stepsEl.textContent = formatNumber(data.today?.steps || 0);
    if (waterEl) waterEl.textContent = data.today?.water || 0;
    if (sleepEl && data.sleep?.length > 0) sleepEl.textContent = data.sleep[data.sleep.length - 1]?.value || '--';
    
    // Render charts
    renderMoodChart(data.moods);
    renderStepsChart(data.steps);
    renderWaterChart(data.water);
    renderSleepChart(data.sleep);
    
    // Render medication compliance
    renderMedicationCompliance(data.medications, data.medication_logs);
  } catch (err) {
    console.error('Error loading health data:', err);
  }
}

function renderMoodChart(moods) {
  const ctx = document.getElementById('mood-chart');
  if (!ctx || !moods) return;
  
  const moodValues = { happy: 5, neutral: 3, sad: 2, tired: 2, sick: 1 };
  
  const labels = moods.map(m => formatDateShort(m.timestamp));
  const values = moods.map(m => moodValues[m.value] || 3);
  
  if (healthCharts.mood) healthCharts.mood.destroy();
  
  healthCharts.mood = new Chart(ctx, {
    type: 'line',
    data: {
      labels,
      datasets: [{
        label: 'Mood',
        data: values,
        borderColor: '#3E7C78',
        backgroundColor: 'rgba(62, 124, 120, 0.1)',
        fill: true,
        tension: 0.4
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      scales: {
        y: { min: 0, max: 5, grid: { display: false } },
        x: { grid: { display: false } }
      },
      plugins: { legend: { display: false } }
    }
  });
}

function renderStepsChart(steps) {
  const ctx = document.getElementById('steps-chart');
  if (!ctx || !steps) return;
  
  const labels = steps.map(s => formatDateShort(s.timestamp));
  const values = steps.map(s => parseInt(s.value) || 0);
  
  if (healthCharts.steps) healthCharts.steps.destroy();
  
  healthCharts.steps = new Chart(ctx, {
    type: 'bar',
    data: {
      labels,
      datasets: [{
        label: 'Steps',
        data: values,
        backgroundColor: '#3E7C78'
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      scales: {
        y: { grid: { display: false } },
        x: { grid: { display: false } }
      },
      plugins: { legend: { display: false } }
    }
  });
}

function renderWaterChart(water) {
  const ctx = document.getElementById('water-chart');
  if (!ctx || !water) return;
  
  // Group by date
  const grouped = {};
  water.forEach(w => {
    const date = w.timestamp.split('T')[0];
    grouped[date] = (grouped[date] || 0) + parseInt(w.value);
  });
  
  const labels = Object.keys(grouped);
  const values = Object.values(grouped);
  
  if (healthCharts.water) healthCharts.water.destroy();
  
  healthCharts.water = new Chart(ctx, {
    type: 'bar',
    data: {
      labels: labels.map(d => formatDateShort(d)),
      datasets: [{
        label: 'Glasses',
        data: values,
        backgroundColor: '#457B9D'
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      scales: {
        y: { grid: { display: false } },
        x: { grid: { display: false } }
      },
      plugins: { legend: { display: false } }
    }
  });
}

function renderSleepChart(sleep) {
  const ctx = document.getElementById('sleep-chart');
  if (!ctx || !sleep) return;
  
  const labels = sleep.map(s => formatDateShort(s.timestamp));
  const values = sleep.map(s => parseFloat(s.value) || 0);
  
  if (healthCharts.sleep) healthCharts.sleep.destroy();
  
  healthCharts.sleep = new Chart(ctx, {
    type: 'bar',
    data: {
      labels,
      datasets: [{
        label: 'Hours',
        data: values,
        backgroundColor: '#A3B18A'
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      scales: {
        y: { grid: { display: false } },
        x: { grid: { display: false } }
      },
      plugins: { legend: { display: false } }
    }
  });
}

function renderMedicationCompliance(medications, logs) {
  const container = document.getElementById('medication-compliance');
  if (!container) return;
  
  if (!medications || medications.length === 0) {
    container.innerHTML = '<p style="color: var(--text-secondary);">No medications configured</p>';
    return;
  }
  
  container.innerHTML = medications.map(med => {
    const medLogs = logs.filter(l => l.medication_id === med.id);
    const takenCount = medLogs.filter(l => l.taken).length;
    
    return `
      <div style="display: flex; justify-content: space-between; padding: 12px 0; border-bottom: 1px solid var(--border-default);">
        <div>
          <strong>${med.name}</strong>
          <span style="color: var(--text-secondary); margin-left: 8px;">${med.dosage || ''}</span>
        </div>
        <div style="color: var(--status-success);">${takenCount} doses taken this week</div>
      </div>
    `;
  }).join('');
}

async function loadPhotos() {
  try {
    const data = await fetchWithAuth(`${API_URL}/media/photos?limit=20`);
    const container = document.getElementById('photo-gallery');
    
    if (!container) return;
    
    if (!data.photos || data.photos.length === 0) {
      container.innerHTML = '<p style="color: var(--text-secondary); text-align: center; padding: 40px;">No photos yet</p>';
      return;
    }
    
    container.innerHTML = data.photos.map(photo => `
      <div class="photo-item" onclick="viewPhoto('${photo.file_url}')">
        <img src="${photo.file_url}" alt="Photo">
        <span class="photo-date">${formatDateShort(photo.created_at)}</span>
      </div>
    `).join('');
  } catch (err) {
    console.error('Error loading photos:', err);
  }
}

function viewPhoto(url) {
  window.open(url, '_blank');
}

async function loadVoiceMessages() {
  try {
    const received = await fetchWithAuth(`${API_URL}/media/voices?direction=from_app&limit=10`);
    const sent = await fetchWithAuth(`${API_URL}/media/voices?direction=to_app&limit=10`);
    
    const receivedContainer = document.getElementById('voice-messages-received');
    const sentContainer = document.getElementById('voice-messages-sent');
    
    if (receivedContainer) {
      if (!received.voices || received.voices.length === 0) {
        receivedContainer.innerHTML = '<p style="color: var(--text-secondary); text-align: center; padding: 20px;">No voice messages received</p>';
      } else {
        receivedContainer.innerHTML = received.voices.map(v => renderVoice(v)).join('');
      }
    }
    
    if (sentContainer) {
      if (!sent.voices || sent.voices.length === 0) {
        sentContainer.innerHTML = '<p style="color: var(--text-secondary); text-align: center; padding: 20px;">No voice messages sent</p>';
      } else {
        sentContainer.innerHTML = sent.voices.map(v => renderVoice(v)).join('');
      }
    }
    
    lucide.createIcons();
  } catch (err) {
    console.error('Error loading voice messages:', err);
  }
}

async function loadSettings() {
  try {
    const data = await fetchWithAuth(`${API_URL}/settings`);
    
    // Populate form fields
    if (data.checkin_interval_hours) {
      document.getElementById('checkin-interval').value = data.checkin_interval_hours;
    }
    if (data.inactivity_threshold_hours) {
      document.getElementById('inactivity-threshold').value = data.inactivity_threshold_hours;
    }
    if (data.speed_alert_kmh) {
      document.getElementById('speed-threshold').value = data.speed_alert_kmh;
    }
    if (data.battery_alert_level) {
      document.getElementById('battery-threshold').value = data.battery_alert_level;
    }
    if (data.father_name) {
      document.getElementById('father-name-input').value = data.father_name;
    }
    if (data.father_phone) {
      document.getElementById('father-phone-input').value = data.father_phone;
    }
    if (data.step_goal) {
      document.getElementById('step-goal-input').value = data.step_goal;
    }
    
    // Load medications
    renderMedicationsList(data.medications);
  } catch (err) {
    console.error('Error loading settings:', err);
  }
}

function renderMedicationsList(medications) {
  const container = document.getElementById('medications-list');
  if (!container) return;
  
  if (!medications || medications.length === 0) {
    container.innerHTML = '<p style="color: var(--text-secondary);">No medications added</p>';
    return;
  }
  
  container.innerHTML = medications.map(med => `
    <div style="display: flex; justify-content: space-between; align-items: center; padding: 12px 0; border-bottom: 1px solid var(--border-default);">
      <div>
        <strong>${med.name}</strong>
        <span style="color: var(--text-secondary); margin-left: 8px;">${med.dosage || ''}</span>
      </div>
      <button class="btn btn-secondary" onclick="deleteMedication(${med.id})" data-testid="delete-med-${med.id}">
        <i data-lucide="trash-2"></i>
      </button>
    </div>
  `).join('');
  
  lucide.createIcons();
}

async function saveGeofence() {
  if (!geofenceCircle || !geofenceCircle.latLng) {
    alert('Please click on the map to set a geofence center');
    return;
  }
  
  const radius = parseInt(document.getElementById('geofence-radius').value) || 500;
  
  try {
    await fetchWithAuth(`${API_URL}/settings/geofence`, {
      method: 'PUT',
      body: JSON.stringify({
        latitude: geofenceCircle.latLng.lat,
        longitude: geofenceCircle.latLng.lng,
        radius: radius,
        name: 'Home'
      })
    });
    
    alert('Geofence saved successfully');
  } catch (err) {
    console.error('Error saving geofence:', err);
    alert('Failed to save geofence');
  }
}

async function saveAlertSettings() {
  try {
    await fetchWithAuth(`${API_URL}/settings`, {
      method: 'PUT',
      body: JSON.stringify({
        checkin_interval_hours: document.getElementById('checkin-interval').value,
        inactivity_threshold_hours: document.getElementById('inactivity-threshold').value,
        speed_alert_kmh: document.getElementById('speed-threshold').value,
        battery_alert_level: document.getElementById('battery-threshold').value
      })
    });
    
    alert('Alert settings saved successfully');
  } catch (err) {
    console.error('Error saving settings:', err);
    alert('Failed to save settings');
  }
}

async function saveProfile() {
  try {
    await fetchWithAuth(`${API_URL}/settings/profile`, {
      method: 'PUT',
      body: JSON.stringify({
        name: document.getElementById('father-name-input').value,
        phone_number: document.getElementById('father-phone-input').value
      })
    });
    
    await fetchWithAuth(`${API_URL}/settings`, {
      method: 'PUT',
      body: JSON.stringify({
        step_goal: document.getElementById('step-goal-input').value
      })
    });
    
    alert('Profile saved successfully');
    loadStatus();
  } catch (err) {
    console.error('Error saving profile:', err);
    alert('Failed to save profile');
  }
}

function addMedication() {
  const name = prompt('Enter medication name:');
  if (!name) return;
  
  const dosage = prompt('Enter dosage (optional):');
  
  fetchWithAuth(`${API_URL}/settings/medications`, {
    method: 'POST',
    body: JSON.stringify({ name, dosage })
  }).then(() => {
    loadSettings();
  }).catch(err => {
    console.error('Error adding medication:', err);
    alert('Failed to add medication');
  });
}

async function deleteMedication(id) {
  if (!confirm('Are you sure you want to delete this medication?')) return;
  
  try {
    await fetchWithAuth(`${API_URL}/settings/medications/${id}`, { method: 'DELETE' });
    loadSettings();
  } catch (err) {
    console.error('Error deleting medication:', err);
  }
}

// Video Call
let peerConnection = null;
let localStream = null;

async function startVideoCall() {
  try {
    const status = document.getElementById('call-status');
    status.textContent = 'Starting call...';
    
    localStream = await navigator.mediaDevices.getUserMedia({ video: true, audio: true });
    document.getElementById('local-video').srcObject = localStream;
    document.getElementById('call-container').style.display = 'block';
    
    // Create peer connection
    peerConnection = new RTCPeerConnection({
      iceServers: [{ urls: 'stun:stun.l.google.com:19302' }]
    });
    
    localStream.getTracks().forEach(track => {
      peerConnection.addTrack(track, localStream);
    });
    
    peerConnection.ontrack = (event) => {
      document.getElementById('remote-video').srcObject = event.streams[0];
    };
    
    peerConnection.onicecandidate = (event) => {
      if (event.candidate) {
        socket.emit('call:ice-candidate', { candidate: event.candidate });
      }
    };
    
    // Create offer
    const offer = await peerConnection.createOffer();
    await peerConnection.setLocalDescription(offer);
    
    socket.emit('call:offer', { offer });
    status.textContent = 'Calling Father...';
    
    // Update UI
    document.getElementById('call-actions').innerHTML = `
      <button class="btn btn-danger" style="padding: 20px 60px; font-size: 18px;" onclick="endCall()" data-testid="end-call-btn">
        <i data-lucide="phone-off"></i>
        End Call
      </button>
    `;
    lucide.createIcons();
    
    // Listen for answer
    socket.on('call:answer', async (data) => {
      await peerConnection.setRemoteDescription(new RTCSessionDescription(data.answer));
      status.textContent = 'Connected';
    });
    
    socket.on('call:ice-candidate', async (data) => {
      if (data.candidate) {
        await peerConnection.addIceCandidate(new RTCIceCandidate(data.candidate));
      }
    });
    
  } catch (err) {
    console.error('Error starting call:', err);
    document.getElementById('call-status').textContent = 'Failed to start call: ' + err.message;
  }
}

function endCall() {
  if (peerConnection) {
    peerConnection.close();
    peerConnection = null;
  }
  
  if (localStream) {
    localStream.getTracks().forEach(track => track.stop());
    localStream = null;
  }
  
  socket.emit('call:hangup');
  
  document.getElementById('call-container').style.display = 'none';
  document.getElementById('call-status').textContent = '';
  document.getElementById('call-actions').innerHTML = `
    <button class="btn btn-primary" style="padding: 20px 60px; font-size: 18px;" onclick="startVideoCall()" data-testid="start-call-btn">
      <i data-lucide="video"></i>
      Start Video Call
    </button>
  `;
  lucide.createIcons();
}

// Messages
function sendTextMessage() {
  const input = document.getElementById('message-text');
  const text = input.value.trim();
  
  if (!text) return;
  
  // Send to app via socket
  socket.emit('message:text', { text, from: user.name || user.username });
  
  input.value = '';
  alert('Message sent');
}

let mediaRecorder = null;
let audioChunks = [];

function toggleRecording() {
  const btn = document.getElementById('record-btn');
  const status = document.getElementById('recording-status');
  
  if (mediaRecorder && mediaRecorder.state === 'recording') {
    mediaRecorder.stop();
    btn.innerHTML = '<i data-lucide="mic"></i> Start Recording';
    status.textContent = 'Processing...';
  } else {
    navigator.mediaDevices.getUserMedia({ audio: true }).then(stream => {
      mediaRecorder = new MediaRecorder(stream);
      audioChunks = [];
      
      mediaRecorder.ondataavailable = (e) => {
        audioChunks.push(e.data);
      };
      
      mediaRecorder.onstop = async () => {
        const blob = new Blob(audioChunks, { type: 'audio/webm' });
        
        // Upload voice message
        const formData = new FormData();
        formData.append('voice', blob, 'voice_message.webm');
        
        try {
          const response = await fetch(`${API_URL}/media/voice/send`, {
            method: 'POST',
            headers: { 'Authorization': `Bearer ${token}` },
            body: formData
          });
          
          if (response.ok) {
            status.textContent = 'Message sent!';
          } else {
            status.textContent = 'Failed to send';
          }
        } catch (err) {
          status.textContent = 'Failed to send';
        }
        
        stream.getTracks().forEach(track => track.stop());
      };
      
      mediaRecorder.start();
      btn.innerHTML = '<i data-lucide="square"></i> Stop Recording';
      status.textContent = 'Recording...';
    }).catch(err => {
      status.textContent = 'Microphone access denied';
    });
  }
  
  lucide.createIcons();
}

// Reports
async function generateReport() {
  const from = document.getElementById('report-from').value;
  const to = document.getElementById('report-to').value;
  
  if (!from || !to) {
    alert('Please select date range');
    return;
  }
  
  try {
    const [locations, alerts, checkins, health] = await Promise.all([
      fetchWithAuth(`${API_URL}/location/range?from=${from}&to=${to}`),
      fetchWithAuth(`${API_URL}/alerts?from=${from}&to=${to}`),
      fetchWithAuth(`${API_URL}/checkin/history?from=${from}&to=${to}`),
      fetchWithAuth(`${API_URL}/health/summary?from=${from}&to=${to}`)
    ]);
    
    // Calculate stats
    const totalSteps = health.steps?.reduce((sum, s) => sum + parseInt(s.value), 0) || 0;
    const totalAlerts = alerts.total || 0;
    const totalCheckins = checkins.length || 0;
    
    // Calculate unique places
    const places = [];
    locations.forEach(loc => {
      const existing = places.find(p => 
        Math.abs(p.latitude - loc.latitude) < 0.001 && 
        Math.abs(p.longitude - loc.longitude) < 0.001
      );
      if (!existing) {
        places.push({ latitude: loc.latitude, longitude: loc.longitude });
      }
    });
    
    // Update UI
    document.getElementById('report-total-steps').textContent = formatNumber(totalSteps);
    document.getElementById('report-total-alerts').textContent = totalAlerts;
    document.getElementById('report-total-checkins').textContent = totalCheckins;
    document.getElementById('report-places-visited').textContent = places.length;
    
    document.getElementById('report-placeholder').style.display = 'none';
    document.getElementById('report-content').style.display = 'block';
    
    // Initialize report map
    setTimeout(() => {
      const container = document.getElementById('report-map-container');
      const reportMap = L.map(container).setView([28.6139, 77.2090], 12);
      
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '© OpenStreetMap contributors'
      }).addTo(reportMap);
      
      if (locations.length > 0) {
        const points = locations.map(loc => [loc.latitude, loc.longitude]);
        L.polyline(points, { color: '#3E7C78', weight: 3 }).addTo(reportMap);
        reportMap.fitBounds(L.polyline(points).getBounds(), { padding: [50, 50] });
      }
    }, 100);
    
    lucide.createIcons();
  } catch (err) {
    console.error('Error generating report:', err);
    alert('Failed to generate report');
  }
}

function exportReport() {
  window.print();
}

// Critical Banner
function showCriticalBanner(alert) {
  const banner = document.getElementById('critical-banner');
  document.getElementById('critical-message').textContent = `${alert.title}: ${alert.message}`;
  banner.classList.add('active');
  
  // Play alert sound
  const audio = new Audio('data:audio/wav;base64,');
  audio.play();
}

function acknowledgeCritical() {
  document.getElementById('critical-banner').classList.remove('active');
  markAllAlertsRead();
}

// Notifications
function showNotification(title, message) {
  if ('Notification' in window && Notification.permission === 'granted') {
    new Notification(title, { body: message, icon: '/favicon.ico' });
  } else if ('Notification' in window && Notification.permission !== 'denied') {
    Notification.requestPermission().then(permission => {
      if (permission === 'granted') {
        new Notification(title, { body: message });
      }
    });
  }
}

// Helper Functions
async function fetchWithAuth(url, options = {}) {
  const response = await fetch(url, {
    ...options,
    headers: {
      'Content-Type': 'application/json',
      'Authorization': `Bearer ${token}`,
      ...options.headers
    }
  });
  
  if (response.status === 401) {
    logout();
    throw new Error('Session expired');
  }
  
  return response.json();
}

function formatTime(timestamp) {
  if (!timestamp) return '--';
  const date = new Date(timestamp);
  return date.toLocaleString();
}

function formatTimeShort(timestamp) {
  if (!timestamp) return '--';
  const date = new Date(timestamp);
  return date.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
}

function formatTimeOnly(date) {
  return date.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
}

function formatDateShort(timestamp) {
  if (!timestamp) return '--';
  const date = new Date(timestamp);
  return date.toLocaleDateString([], { month: 'short', day: 'numeric' });
}

function formatNumber(num) {
  return num.toLocaleString();
}

function formatDuration(seconds) {
  const mins = Math.floor(seconds / 60);
  const secs = seconds % 60;
  return `${mins}:${secs.toString().padStart(2, '0')}`;
}

function getMoodEmoji(mood) {
  const emojis = {
    happy: '😊',
    neutral: '😐',
    sad: '😟',
    tired: '😴',
    sick: '🤒'
  };
  return emojis[mood] || '😐';
}

function toggleUserMenu() {
  // Simple toggle - could be enhanced with dropdown
  if (confirm('Logout?')) {
    logout();
  }
}

// Request notification permission on load
if ('Notification' in window) {
  Notification.requestPermission();
}
