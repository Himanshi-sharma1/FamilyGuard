async function loadRecentVoices() {
  try {
    const data = await fetchWithAuth(`${API_URL}/media/voices?limit=3&direction=from_app`);
    const container = document.getElementById('recent-voices');
    
    if (!container) return;
    
    if (!data.voices || data.voices.length === 0) {
      container.innerHTML = '<p style="color: var(--text-secondary); text-align: center; padding: 20px;">No voice messages</p>';
      return;
    }
    
    container.innerHTML = data.voices.map(voice => renderVoice(voice)).join('');
    lucide.createIcons();
